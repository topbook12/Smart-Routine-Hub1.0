// Smart Routine Hub — Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String
  passwordHash String
  pinHash      String?
  designation  String?
  department   String   @default("ICE, RU")
  phone        String?
  photoURL     String?
  officeRoom   String?
  bio          String?
  role         String   @default("teacher") // "admin" | "teacher"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  schedules       Schedule[]       @relation("TeacherSchedules")
  scheduleChanges ScheduleChange[] @relation("ChangedBy")
  notices         Notice[]         @relation("PostedBy")
}

model Course {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  creditHours Float    @default(3)
  type        String   @default("theory") // "theory" | "lab"
  semester    Int
  program     String   @default("bsc") // "bsc" | "msc"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  schedules Schedule[]
}

model Room {
  id         String   @id @default(cuid())
  roomNumber String   @unique
  building   String?
  type       String   @default("classroom") // "classroom" | "lab" | "seminar"
  capacity   Int      @default(40)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  schedules Schedule[]
}

model TimeSlot {
  id        String  @id @default(cuid())
  label     String
  startTime String
  endTime   String
  slotOrder Int
  isBreak   Boolean @default(false)
  isActive  Boolean @default(true)
}

model Schedule {
  id           String   @id @default(cuid())
  courseId     String
  teacherId    String
  roomId       String
  timeSlotId   String?
  courseName   String
  courseCode   String
  teacherName  String
  teacherInitials String?
  roomNumber   String
  startTime    String
  endTime      String
  dayOfWeek    String // Saturday..Thursday
  semester     Int
  program      String   @default("bsc")
  section      String?
  classType    String   @default("theory")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course         Course         @relation(fields: [courseId], references: [id])
  teacher        User           @relation("TeacherSchedules", fields: [teacherId], references: [id])
  room           Room           @relation(fields: [roomId], references: [id])
  scheduleChanges ScheduleChange[]
}

model ScheduleChange {
  id                 String   @id @default(cuid())
  scheduleId         String?
  changeType         String   // "cancelled" | "rescheduled" | "room_changed" | "extra_class"
  originalDay        String?
  originalStartTime  String?
  originalEndTime    String?
  originalRoomId     String?
  originalRoomNumber String?
  newDay             String?
  newStartTime       String?
  newEndTime         String?
  newRoomId          String?
  newRoomNumber      String?
  effectiveDate      DateTime?
  reason             String?
  courseName         String?
  courseCode         String?
  teacherId          String?
  teacherName        String?
  semester           Int?
  program            String?
  changedById        String?
  changedByName      String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  schedule  Schedule? @relation(fields: [scheduleId], references: [id])
  changedBy User?     @relation("ChangedBy", fields: [changedById], references: [id])
}

model Notice {
  id                String    @id @default(cuid())
  title             String
  content           String
  category          String    @default("general") // "academic" | "exam" | "event" | "general" | "schedule_change"
  changeType        String?
  scheduleChangeId  String?
  affectedSemester  Int?
  affectedProgram   String?
  postedById        String?
  postedByName      String?
  isPinned          Boolean   @default(false)
  isApproved        Boolean   @default(true)
  isAutoGenerated   Boolean   @default(false)
  attachmentURL     String?
  expiryDate        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  postedBy User? @relation("PostedBy", fields: [postedById], references: [id])
}

model LibraryLink {
  id        String   @id @default(cuid())
  degree    String   // "bsc" | "msc" | "others"
  semester  Int?
  url       String
  title     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
